<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RoundedCorner_8dp">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Theme.Bilibili" parent="Theme.AppCompat.Light.NoActionBar" />

    <style name="BottomBarTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorPrimary">#FB7299</item>
        <item name="colorOnSurface">#757575</item>
    </style>

    <style name="BiliUploadItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="BiliUploadItemTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="UserStatItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="UserStatNumberStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#212121</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="UserStatLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#999999</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

    <style name="MyTabTextStyle">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="PinkDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">#FB7299</item>
    </style>

    <style name="SearchHistoryChipStyle" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">#F6F6F6</item>
        <item name="chipCornerRadius">4dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">13sp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxWidth">160dp</item>
    </style>

    <style name="Theme.Bilibili.Search" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#FB7299</item>
        <item name="colorPrimaryVariant">#FB7299</item>
        <item name="colorSecondary">#FB7299</item>
    </style>

    <style name="BiliTabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
    </style>

</resources>