<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="RoundedCorner_8dp">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Theme.Bilibili" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorAccent">@color/bili_pink</item>
        <item name="colorControlActivated">@color/bili_pink</item>
        <item name="editTextStyle">@style/BilibiliEditTextStyle</item>
    </style>

    <style name="Theme.Bilibili.Splash" parent="Theme.Bilibili">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="BottomBarTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorPrimary">#FB7299</item>
        <item name="colorOnSurface">#757575</item>
    </style>

    <style name="BiliUploadItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
    </style>

    <style name="BiliUploadItemTextStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="PartTitleBottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
        <item name="android:editTextStyle">@style/BilibiliEditTextStyle</item>
        <item name="editTextStyle">@style/BilibiliEditTextStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="NoDimBottomSheetStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/NoDimCustomBottomSheetStyle</item>
    </style>

    <style name="NoDimCustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/white</item>
        <item name="android:windowIsFloating">false</item>
        <item name="behavior_peekHeight">500dp</item>
        <item name="behavior_hideable">false</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage4">
        <item name="cornerSize">4dp</item>
    </style>

    <style name="UserStatItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="UserStatNumberStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#212121</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="UserStatLabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#999999</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

    <style name="MyTabTextStyle">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="PinkDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">#FB7299</item>
        <item name="android:textColorPrimary">#333333</item>
        <item name="buttonBarPositiveButtonStyle">@style/PinkDialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/PinkDialogButtonStyle</item>
    </style>

    <style name="PinkDialogButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#FB7299</item>
    </style>

    <!-- Material 主题 Activity（如 SearchActivity）需用此样式，否则按钮可能不可见 -->
    <style name="PinkMaterialDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">#FB7299</item>
        <item name="colorAccent">#FB7299</item>
        <item name="android:textColorPrimary">#333333</item>
        <item name="buttonBarPositiveButtonStyle">@style/PinkMaterialDialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/PinkMaterialDialogButtonStyle</item>
    </style>

    <style name="PinkMaterialDialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FB7299</item>
    </style>

    <style name="SearchHistoryChipStyle" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">#F6F6F6</item>
        <item name="chipCornerRadius">4dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">13sp</item>
        <item name="chipMinHeight">32dp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxWidth">160dp</item>
    </style>

    <style name="Theme.Bilibili.Search" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#FB7299</item>
        <item name="colorPrimaryVariant">#FB7299</item>
        <item name="colorSecondary">#FB7299</item>
        <item name="colorControlActivated">@color/bili_pink</item>
        <item name="editTextStyle">@style/BilibiliEditTextStyle</item>
    </style>

    <style name="BiliTabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="BilibiliDatePickerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">#FB7299</item>
        <item name="colorPrimary">#FB7299</item>
        <item name="colorControlActivated">#FB7299</item>
    </style>

    <style name="ConventionLanguageTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:textColor">#61666D</item>
        <item name="android:textSize">13sp</item>
        <item name="android:background">@drawable/bg_convention_tab_normal</item>
    </style>

    <style name="BilibiliEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="colorAccent">@color/bili_pink</item>
        <item name="colorControlActivated">@color/bili_pink</item>
        <item name="colorControlHighlight">@color/bili_pink</item>
        <item name="colorControlNormal">#CCCCCC</item>
        <item name="android:textColorHighlight">#33FB7299</item>
        <item name="android:textCursorDrawable">@drawable/cursor_drawable</item>
        <item name="android:textSelectHandle">@drawable/text_cursor_handle_middle</item>
        <item name="android:textSelectHandleLeft">@drawable/text_cursor_handle_left</item>
        <item name="android:textSelectHandleRight">@drawable/text_cursor_handle_right</item>
    </style>

</resources>