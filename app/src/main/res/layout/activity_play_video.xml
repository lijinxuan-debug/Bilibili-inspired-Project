<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 视频播放器容器 -->
    <FrameLayout
        android:id="@+id/player_container"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#000000"
        app:layout_constraintTop_toTopOf="parent">

        <com.example.bilibili.ui.playVideo.DanmakuVideoPlayer
            android:id="@+id/video_player"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/iv_sticky_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="@color/white" />
    </FrameLayout>

    <!-- TabLayout 和 弹幕输入框容器 -->
    <RelativeLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/player_container">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/video_tab_layout"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@color/white"
            app:tabGravity="start"
            app:tabIndicatorColor="#FB7299"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorHeight="2.5dp"
            app:tabMinWidth="80dp"
            app:tabMode="fixed"
            app:tabPaddingEnd="12dp"
            app:tabPaddingStart="12dp"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="#FB7299"
            app:tabTextAppearance="@style/BiliTabTextStyle"
            app:tabTextColor="#61666D">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="简介" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="评论 204" />

        </com.google.android.material.tabs.TabLayout>

        <LinearLayout
            android:id="@+id/ll_danmu_bar"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_barrage_input"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <!-- 仅裁剪容器宽度，内部文案保持完整宽度，避免挤压换行 -->
            <FrameLayout
                android:id="@+id/fl_danmu_expand_clip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="true">

                <LinearLayout
                    android:id="@+id/ll_danmu_expandable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/danmu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="点我发弹幕"
                        android:textColor="#999999"
                        android:textSize="12sp" />

                    <View
                        android:id="@+id/v_danmu_divider"
                        android:layout_width="1dp"
                        android:layout_height="14dp"
                        android:layout_marginHorizontal="8dp"
                        android:background="#E3E5E7" />
                </LinearLayout>
            </FrameLayout>

            <ImageView
                android:id="@+id/iv_danmu_switch"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/sl_danmu_switch" />
        </LinearLayout>
    </RelativeLayout>

    <!-- ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_container" />

</androidx.constraintlayout.widget.ConstraintLayout>