<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ImageView
        android:id="@+id/iv_banner"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:paddingTop="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_profile_banner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 退出登录：实心白圆底 + 深色图标（右上角，仅已登录时显示） -->
    <ImageView
        android:id="@+id/iv_logout"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="@dimen/personal_logout_margin_top"
        android:layout_marginEnd="@dimen/personal_logout_margin_end"
        android:background="@drawable/bg_circle_white_border"
        android:clickable="true"
        android:contentDescription="@string/logout"
        android:focusable="true"
        android:padding="9dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_logout"
        android:translationZ="1dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#3D3D3D"
        tools:visibility="visible" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_avatar"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="16dp"
        android:clickable="true"
        android:contentDescription="@string/edit_profile_avatar"
        android:focusable="true"
        android:padding="2dp"
        android:src="@drawable/ic_avatar_default"

        android:translationY="20dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_banner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_banner"
        app:shapeAppearanceOverlay="@style/CircleImage" />

    <LinearLayout
        android:id="@+id/ll_stats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="8dp"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_avatar"
        app:layout_constraintTop_toBottomOf="@id/iv_banner">

        <LinearLayout
            android:id="@+id/layout_fans_stat"
            style="@style/UserStatItemStyle"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_fans_count"
                style="@style/UserStatNumberStyle"
                android:text="209" />

            <TextView
                style="@style/UserStatLabelStyle"
                android:text="粉丝" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="#EEEEEE" />

        <LinearLayout
            android:id="@+id/layout_follow_stat"
            style="@style/UserStatItemStyle"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_follow_count"
                style="@style/UserStatNumberStyle"
                android:text="46" />

            <TextView
                style="@style/UserStatLabelStyle"
                android:text="关注" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="14dp"
            android:background="#EEEEEE" />

        <LinearLayout
            android:id="@+id/layout_like_stat"
            style="@style/UserStatItemStyle"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tv_like_count"
                style="@style/UserStatNumberStyle"
                android:text="1453" />

            <TextView
                style="@style/UserStatLabelStyle"
                android:text="获赞" />
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_logout"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_pink_border"
        android:gravity="center"
        android:padding="0dp"
        android:text="编辑资料"
        android:textColor="#FB7299"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/ll_stats"
        app:layout_constraintTop_toBottomOf="@+id/ll_stats" />

    <TextView
        android:id="@+id/tv_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="xixi开了"
        android:textColor="#212121"
        android:textSize="20sp"

        android:textStyle="bold"

        app:layout_constraintStart_toStartOf="@+id/iv_avatar"
        app:layout_constraintTop_toBottomOf="@id/btn_logout" />

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="加我V19503665215，并且关注一下"
        android:textColor="#757575"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tv_nickname"
        app:layout_constraintTop_toBottomOf="@id/tv_nickname" />

    <LinearLayout
        android:id="@+id/row_school"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_nickname"
        app:layout_constraintTop_toBottomOf="@id/tv_description">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_school"
            app:tint="#999999" />

        <TextView
            android:id="@+id/tv_school"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#999999"
            android:textSize="13sp"
            tools:text="新乡职业技术学院" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_uid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="2dp"
        app:layout_constraintStart_toStartOf="@id/tv_nickname"
        app:layout_constraintTop_toBottomOf="@id/row_school">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_meta_label"
            android:paddingHorizontal="3dp"
            android:paddingVertical="1dp"
            android:text="UID"
            android:textColor="#999999"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tv_uid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#999999"
            android:textSize="13sp"
            tools:text="1636906786" />
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@color/white"

        app:layout_constraintTop_toBottomOf="@id/row_uid"
        app:tabIndicatorColor="#FB7299"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="2.5dp"
        app:tabMode="fixed"
        app:tabRippleColor="@android:color/transparent"
        app:tabSelectedTextColor="#FB7299"
        app:tabTextAppearance="@style/MyTabTextStyle"
        app:tabTextColor="#757575" />

    <View
        android:id="@+id/tab_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F4F4F4"
        app:layout_constraintTop_toBottomOf="@id/tab_layout" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tab_divider" />

    <View
        android:id="@+id/loading_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:clickable="true"
        android:focusable="true"
        android:visibility="visible"

        tools:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>